# Base publique utilisée dans redirect_uri (sans slash final).
# Exemple prod : https://votredomaine.com
# Exemple local : http://localhost:3000
# Dans chaque console OAuth (Google, Microsoft, etc.), enregistrer exactement :
#   {OAUTH_REDIRECT_BASE}/api/oauth/connectors/callback
OAUTH_REDIRECT_BASE=http://localhost:3000

# --- 1) Documents & cloud : Google Drive (lecture) ---
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
# Optionnel (scopes séparés par des espaces)
# OAUTH_GOOGLE_SCOPES=https://www.googleapis.com/auth/drive.readonly openid email

# --- 2) SSO & annuaire : Microsoft Entra (common) ---
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
# OAUTH_MICROSOFT_SCOPES=openid profile offline_access User.Read

# --- 3) Wikis : Notion ---
OAUTH_NOTION_CLIENT_ID=
OAUTH_NOTION_CLIENT_SECRET=

# --- 4) Messagerie : Slack (OAuth v2) ---
OAUTH_SLACK_CLIENT_ID=
OAUTH_SLACK_CLIENT_SECRET=
# OAUTH_SLACK_BOT_SCOPES=channels:read,chat:write
# OAUTH_SLACK_USER_SCOPES=

# --- 5) CRM : HubSpot ---
OAUTH_HUBSPOT_CLIENT_ID=
OAUTH_HUBSPOT_CLIENT_SECRET=
# OAUTH_HUBSPOT_SCOPES=oauth crm.objects.contacts.read

# --- 6) Zoom (OAuth utilisateur) ---
# Créer une app OAuth sur https://marketplace.zoom.us/ — Redirect URL = {OAUTH_REDIRECT_BASE}/api/oauth/connectors/callback
# L’URL d’auth est https://zoom.us/oauth/authorize (Zoom peut afficher zoom.us/signin?continue=… comme pour Claude).
# Dans Zoom → Scopes : « + Add Scopes » et ajouter les MÊMES IDs que ci-dessous (sinon « périmètre non valide »).
# Défaut serveur si vous ne définissez pas OAUTH_ZOOM_SCOPES : user + liste réunions + enregistrements cloud utilisateur.
# Pour tester au minimum : dans Zoom ajoutez seulement user:read:user puis définissez :
# OAUTH_ZOOM_SCOPES=user:read:user
OAUTH_ZOOM_CLIENT_ID=
OAUTH_ZOOM_CLIENT_SECRET=
# OAUTH_ZOOM_SCOPES=user:read:user meeting:read:list_meetings cloud_recording:read:list_user_recordings
